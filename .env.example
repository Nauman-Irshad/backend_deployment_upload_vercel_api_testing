# Cloudinary (required)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: JSON file for /records (default: ./data/records.json under this app)
# Use an absolute path if you mount a persistent disk (e.g. on Render)
# RECORDS_PATH=/var/data/records.json

# CORS
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
